API_PORT=8080
DEFAULT_CURRENCY_CODE=EUR

LOG_LEVEL=INFO
LOG_ADD_SOURCE=false
LOG_USE_JSON=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

DB_URL=postgres://postgres:postgres@localhost:5432/avion?sslmode=disable
DB_AUTO_MIGRATE=true

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECT_ATTEMPTS=3
REDIS_CONNECT_RETRY_DELAY_SECONDS=1
REDIS_SESSION_TTL_HOURS=24
REDIS_CALENDAR_TTL_HOURS=720

TF_BASE_URL=http://api.travelfusion.com
TF_XML_LOGIN_ID=
TF_LOGIN_ID=
TF_TIMEOUT_SECONDS=60
TF_POLLING_ATTEMPTS=10
TF_POLLING_DELAY_SECONDS=2
TF_OPERATOR_LOGO_URL_PATTERN=https://www.travelfusion.com/images/operators/p%s.gif
TF_CURRENCIES_UPDATE_CRON=0 0 3 * * ?
TF_CURRENCIES_UPDATE_TIME=03:00
TF_ROUTES_UPDATE_CRON=0 0 4 * * ?
TF_ROUTES_UPDATE_TIME=04:00

GOOGLE_SHEETS_CONTACT_DETAILS_ENABLED=false
GOOGLE_SHEETS_CREDENTIALS_FILE=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CONTACT_DETAILS_RANGE=Contacts!A:C
